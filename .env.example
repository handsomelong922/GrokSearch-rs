# Grok Responses-compatible gateway. Provide root URL or /v1; endpoint is normalized automatically.
# Auth modes:
#   api_key: use GROK_SEARCH_API_KEY
#   oauth: run `grok-search-rs login`, then set GROK_SEARCH_AUTH_MODE=oauth
GROK_SEARCH_AUTH_MODE=api_key
# GROK_SEARCH_AUTH_FILE=C:\Users\you\.config\grok-search-rs\auth.json
GROK_SEARCH_API_KEY=your-grok-compatible-key
GROK_SEARCH_URL=https://api.x.ai
GROK_SEARCH_MODEL=grok-4-1-fast-reasoning

# web_search is enabled by default. x_search is disabled by default.
GROK_SEARCH_WEB_SEARCH=true
GROK_SEARCH_X_SEARCH=false

# Tavily provides extra sources, URL fetch, and site map. Enabled by default when a key is present.
# Multiple keys: comma-separate them (TAVILY_API_KEY=tvly-a,tvly-b) for round-robin
# rotation with automatic failover on key-scoped errors (401/403/429/432/433).
TAVILY_API_KEY=tvly-your-key
TAVILY_API_URL=https://api.tavily.com
# TAVILY_ENABLED=false

# Firecrawl provides fetch fallback and supplemental source fallback. Enabled by default when a key is present.
# Multiple keys: comma-separate them (FIRECRAWL_API_KEY=fc-a,fc-b) for round-robin
# rotation with automatic failover on key-scoped errors (401/402/403/429).
# FIRECRAWL_API_KEY=fc-your-key
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_ENABLED=false

# ── OpenAI-compatible transport (alternative to GROK_SEARCH_*) ───
# When GROK_SEARCH_API_KEY above is unset and these three are set,
# grok-search-rs talks to /v1/chat/completions instead of /v1/responses.
# Useful for OpenAI-compatible gateways that do not implement /responses.
# OPENAI_COMPATIBLE_API_URL=https://your-gateway/v1
# OPENAI_COMPATIBLE_API_KEY=sk-...
# OPENAI_COMPATIBLE_MODEL=grok-4.3-fast

# Search source behavior.
GROK_SEARCH_EXTRA_SOURCES=3
GROK_SEARCH_FALLBACK_SOURCES=5
GROK_SEARCH_CACHE_SIZE=256
GROK_SEARCH_TIMEOUT_SECONDS=60

# Optional HTTP transport for hosted deployments such as Hugging Face Spaces.
# Set GROK_SEARCH_MCP_TRANSPORT=http or run `grok-search-rs serve-http`.
# The MCP endpoint is /mcp; HOST/PORT default to 0.0.0.0:3000 locally.
# GROK_SEARCH_MCP_TRANSPORT=http
# GROK_SEARCH_HTTP_PORT=3000
